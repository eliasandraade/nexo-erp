{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=nexo;Username=nexo_user;Password=nexo_password",
    "Redis": ""
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS",
    "Issuer": "nexo-api",
    "Audience": "nexo-frontend",
    "RefreshAudience": "nexo-refresh",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "App": {
    "FrontendUrl": "http://localhost:5173"
  },
  "AllowedHosts": "*",
  "Integrations": {
    "BrasilApi": {
      "BaseUrl": "https://brasilapi.com.br/api",
      "TimeoutSeconds": 8
    },
    "ViaCep": {
      "BaseUrl": "https://viacep.com.br/ws",
      "TimeoutSeconds": 6
    },
    "Features": {
      "BrasilApiEnabled": true,
      "ViaCepEnabled": true,
      "OpenFoodFactsEnabled": false,
      "StorageEnabled": false,
      "PdfEnabled": false,
      "WeatherEnabled": false,
      "StripeEnabled": false,
      "MercadoPagoEnabled": false,
      "WhatsAppEnabled": false,
      "FiscalEnabled": false
    },
    "Http": {
      "DefaultTimeoutSeconds": 10,
      "MaxResponseContentMb": 5
    },
    "Resilience": {
      "MaxRetryAttempts": 3,
      "RetryBaseDelaySeconds": 1.0,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerBreakDurationSeconds": 60
    }
  }
}
