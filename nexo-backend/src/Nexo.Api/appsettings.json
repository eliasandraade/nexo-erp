{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=nexo;Username=nexo_user;Password=nexo_password",
    "Redis": ""
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS",
    "Issuer": "nexo-api",
    "Audience": "nexo-frontend",
    "RefreshAudience": "nexo-refresh",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
